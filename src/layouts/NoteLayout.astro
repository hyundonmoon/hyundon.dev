---
import Prose from "@components/Prose.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"notes">["data"];
const { title, pubDate, updatedDate, summary } = Astro.props;

const formatDate = (date: Date) => date.toISOString().split("T")[0];
---

<BaseLayout pageTitle={`${title} | Hyun Don Moon`} pageDescription={summary}>
  <article>
    <div class="mb-8 pb-4 border-b border-terminal-border">
      <h1 class="text-xl font-bold text-terminal-text mb-2">{title}</h1>
      <div class="text-terminal-faint text-[0.75rem]">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {
          updatedDate && (
            <span>
              {" "}· Updated:{" "}
              <time datetime={updatedDate.toISOString()}>
                {formatDate(updatedDate)}
              </time>
            </span>
          )
        }
      </div>
    </div>
    <Prose>
      <slot />
    </Prose>
  </article>
</BaseLayout>
