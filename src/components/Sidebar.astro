---
const navLinks = [
  { href: "/about/", label: "about" },
  { href: "/notes/", label: "notes" },
];
const socialLinks = [
  { href: "https://github.com/hyundonmoon", label: "github" },
  { href: "https://www.linkedin.com/in/hyundonmoon/", label: "linkedin" },
  { href: "/rss.xml", label: "rss" },
];
---

<aside class="sidebar">
  <div class="text-[1rem] font-bold mb-1">
    <a href="/" class="text-terminal-green no-underline green-glow">
      hyundon.dev
    </a>
  </div>

  <p class="text-[0.8rem] text-terminal-faint font-light leading-relaxed mb-6">
    Hyun Don Moon<br />Developer, sometimes writer.<br />Seoul, South Korea
  </p>

  <div class="section-label">Pages</div>
  <nav>
    {
      navLinks.map(({ href, label }, i) => (
        <a
          href={href}
          class:list={["nav-link", { "first-link": i === 0 }]}
          data-astro-prefetch
        >
          {label}
          <span class="arrow">&rarr;</span>
        </a>
      ))
    }
  </nav>

  <div class="section-label">Elsewhere</div>
  <ul class="links-list">
    {
      socialLinks.map(({ href, label }) => {
        const isExternal = href.startsWith("http");
        return (
          <li>
            <a
              href={href}
              class="social-link"
              {...(isExternal
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
            >
              <span class="tilde">~</span>
              {label}
            </a>
          </li>
        );
      })
    }
  </ul>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 4rem;
    align-self: start;
    border-right: 1px solid theme("colors.terminal.border");
    padding-right: 1.5rem;
  }

  .section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: theme("colors.terminal.faint");
    margin-bottom: 0.4rem;
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 1.5rem;
  }

  .nav-link {
    color: theme("colors.terminal.dim");
    text-decoration: none;
    font-size: 0.875rem;
    padding: 0.45em 0;
    border-bottom: 1px solid theme("colors.terminal.border");
    transition: all 0.15s;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-link.first-link {
    border-top: 1px solid theme("colors.terminal.border");
  }

  .arrow {
    opacity: 0;
    color: theme("colors.terminal.green");
    transition: opacity 0.15s;
    font-size: 0.75rem;
  }

  .nav-link:hover {
    color: theme("colors.terminal.green");
  }

  .nav-link:hover .arrow {
    opacity: 1;
  }

  .links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0;
  }

  .social-link {
    color: theme("colors.terminal.faint");
    text-decoration: none;
    font-size: 0.8rem;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .tilde {
    font-size: 0.7rem;
    color: theme("colors.terminal.faint");
  }

  .social-link:hover {
    color: theme("colors.terminal.green");
    text-shadow: 0 0 6px rgba(57, 211, 83, 0.25);
  }

  .social-link:hover .tilde {
    color: theme("colors.terminal.green");
  }

  @media (max-width: 700px) {
    .sidebar {
      position: static;
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid theme("colors.terminal.border");
      padding-bottom: 1.5rem;
    }

    nav {
      flex-direction: row;
      gap: 1rem;
    }

    .nav-link {
      border: none;
      padding: 0;
    }

    .nav-link.first-link {
      border: none;
    }

    .arrow {
      display: none;
    }

    .links-list {
      flex-direction: row;
      gap: 1rem;
    }
  }
</style>
