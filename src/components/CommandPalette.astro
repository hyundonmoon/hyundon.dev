---
import { getCollection } from "astro:content";
import { formatDate } from "@lib/notes.ts";

const notes = await getCollection("notes");
const sortedNotes = notes.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pages = [
  { title: "Home", href: "/", type: "page" as const },
  { title: "About", href: "/about/", type: "page" as const },
  { title: "Notes", href: "/notes/", type: "page" as const },
];

const noteItems = sortedNotes.map((note) => ({
  title: note.data.title,
  href: `/notes/${note.id}/`,
  type: "note" as const,
  date: formatDate(note.data.pubDate),
}));

const searchItems = [...pages, ...noteItems];
---

<div id="command-palette" class="palette-backdrop" aria-modal="true" role="dialog" aria-label="Command palette">
  <div class="palette-modal">
    <div class="palette-input-row">
      <span class="palette-label">⌘K</span>
      <input
        id="palette-input"
        type="text"
        class="palette-input"
        placeholder="Search pages and notes..."
        autocomplete="off"
      />
    </div>
    <div id="palette-results" class="palette-results"></div>
    <div class="palette-footer">
      <span>↑↓ navigate</span>
      <span>↵ open</span>
      <span>esc close</span>
    </div>
  </div>
</div>

<script is:inline set:html={`window.__SEARCH_ITEMS__ = ${JSON.stringify(searchItems)};`} />

<script>
  const items = window.__SEARCH_ITEMS__;
  const backdrop = document.getElementById("command-palette")!;
  const input = document.getElementById("palette-input")! as HTMLInputElement;
  const resultsContainer = document.getElementById("palette-results")!;
  let highlightIndex = 0;
  let currentResults: typeof items = [];

  function esc(s: string) {
    const d = document.createElement("div");
    d.textContent = s;
    return d.innerHTML;
  }

  function open() {
    backdrop.classList.add("visible");
    document.body.style.overflow = "hidden";
    input.value = "";
    highlightIndex = 0;
    render(items);
    input.focus();
  }

  function close() {
    backdrop.classList.remove("visible");
    document.body.style.overflow = "";
    input.blur();
  }

  function render(filtered: typeof items) {
    currentResults = filtered;
    const pages = filtered.filter((i: any) => i.type === "page");
    const notes = filtered.filter((i: any) => i.type === "note");

    if (filtered.length === 0) {
      resultsContainer.innerHTML =
        '<div class="palette-empty">No results found</div>';
      return;
    }

    let html = "";

    if (pages.length > 0) {
      html += '<div class="palette-group-label">Pages</div>';
      pages.forEach((item: any, i: number) => {
        const idx = i;
        html += `<div class="palette-item${idx === highlightIndex ? " highlighted" : ""}" data-index="${idx}" data-href="${esc(item.href)}">
          <span class="palette-item-title">${esc(item.title)}</span>
          <span class="palette-item-meta">${esc(item.href)}</span>
        </div>`;
      });
    }

    if (notes.length > 0) {
      html += '<div class="palette-group-label">Notes</div>';
      notes.forEach((item: any, i: number) => {
        const idx = pages.length + i;
        html += `<div class="palette-item${idx === highlightIndex ? " highlighted" : ""}" data-index="${idx}" data-href="${esc(item.href)}">
          <span class="palette-item-title">${esc(item.title)}</span>
          <span class="palette-item-meta">${esc(item.date || "")}</span>
        </div>`;
      });
    }

    resultsContainer.innerHTML = html;

    resultsContainer.querySelectorAll(".palette-item").forEach((el) => {
      el.addEventListener("click", () => {
        window.location.href = (el as HTMLElement).dataset.href!;
      });
    });
  }

  function updateHighlight(delta: number) {
    if (currentResults.length === 0) return;
    highlightIndex =
      (highlightIndex + delta + currentResults.length) % currentResults.length;
    render(currentResults);

    const highlighted = resultsContainer.querySelector(".highlighted");
    if (highlighted) {
      highlighted.scrollIntoView({ block: "nearest" });
    }
  }

  input.addEventListener("input", () => {
    const query = input.value.toLowerCase();
    const filtered = items.filter((item: any) =>
      item.title.toLowerCase().includes(query),
    );
    highlightIndex = 0;
    render(filtered);
  });

  document.addEventListener("keydown", (e) => {
    const tag = (e.target as HTMLElement)?.tagName;
    const isOpen = backdrop.classList.contains("visible");
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      if (!isOpen && (tag === "INPUT" || tag === "TEXTAREA")) return;
      e.preventDefault();
      if (isOpen) {
        close();
      } else {
        open();
      }
      return;
    }

    if (!backdrop.classList.contains("visible")) return;

    if (e.key === "Escape") {
      e.preventDefault();
      close();
    } else if (e.key === "ArrowDown") {
      e.preventDefault();
      updateHighlight(1);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      updateHighlight(-1);
    } else if (e.key === "Enter") {
      e.preventDefault();
      if (currentResults.length > 0 && currentResults[highlightIndex]) {
        window.location.href = currentResults[highlightIndex].href;
      }
    } else if (e.key === "Tab") {
      e.preventDefault();
      input.focus();
    }
  });

  backdrop.addEventListener("click", (e) => {
    if (e.target === backdrop) {
      close();
    }
  });
</script>

<style>
  .palette-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
    justify-content: center;
    align-items: flex-start;
    padding-top: 20vh;
  }

  .palette-backdrop.visible {
    display: flex;
  }

  .palette-modal {
    width: 100%;
    max-width: 500px;
    margin: 0 1rem;
    background: theme("colors.terminal.bg");
    border: 1px solid theme("colors.terminal.border");
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  .palette-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid theme("colors.terminal.border");
  }

  .palette-label {
    color: theme("colors.terminal.green");
    font-size: 0.8rem;
    font-weight: bold;
    flex-shrink: 0;
  }

  .palette-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: theme("colors.terminal.text");
    font-family: inherit;
    font-size: 0.85rem;
    caret-color: theme("colors.terminal.green");
  }

  .palette-input::placeholder {
    color: theme("colors.terminal.faint");
  }

  .palette-results {
    max-height: 300px;
    overflow-y: auto;
  }

  .palette-group-label {
    padding: 0.4rem 1rem 0.2rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: theme("colors.terminal.faint");
  }

  .palette-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: background 0.1s;
  }

  .palette-item:hover,
  .palette-item.highlighted {
    background: theme("colors.terminal.surface");
  }

  .palette-item-title {
    color: theme("colors.terminal.dim");
    font-size: 0.8rem;
  }

  .palette-item.highlighted .palette-item-title {
    color: theme("colors.terminal.text");
  }

  .palette-item-meta {
    color: theme("colors.terminal.faint");
    font-size: 0.65rem;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .palette-empty {
    padding: 1.5rem 1rem;
    text-align: center;
    color: theme("colors.terminal.faint");
    font-size: 0.8rem;
  }

  .palette-footer {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    border-top: 1px solid theme("colors.terminal.border");
    color: theme("colors.terminal.faint");
    font-size: 0.6rem;
  }
</style>
