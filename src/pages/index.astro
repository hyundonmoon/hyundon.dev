---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import currently from "@data/currently.json";
import { formatDate, tagColors } from "@lib/notes.ts";

const notes = await getCollection("notes");
const recentNotes = notes
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  pageTitle="hyundon.dev"
  pageDescription="Hyun Don Moon — Developer, sometimes writer. Seoul, South Korea."
>
  <!-- Terminal flair intro -->
  <div class="mb-10">
    <div class="mb-1.5">
      <span class="text-terminal-green">~</span>
      <span class="text-terminal-dim">$</span> whoami
    </div>
    <p class="text-[1.1rem] leading-[1.7]">
      Hi! I'm <strong>Hyun Don</strong>, a front-end web developer based in
      Seoul, South Korea.<span class="cursor"></span>
    </p>
    <p class="text-terminal-dim text-base leading-[1.7] mt-2.5">
      This is where I share what I'm learning as I grow as a web developer,
      showcase my interests, and occasionally post updates about what's going on
      in my life. Thanks for dropping by!
    </p>
  </div>

  <!-- Currently section -->
  <div class="mb-10">
    <div
      class="text-[0.75rem] uppercase tracking-[0.15em] text-terminal-dim border-b border-terminal-border pb-1.5 mb-2.5"
    >
      Currently
    </div>
    <div class="text-terminal-dim text-[0.9rem] leading-[2]">
      {
        currently.map(({ label, value }) => (
          <div>
            <span class="text-terminal-green">{label}</span>
            <span class="text-terminal-faint mx-1">&mdash;</span>
            {value}
          </div>
        ))
      }
    </div>
  </div>

  <!-- Recent Notes -->
  <div>
    <div
      class="flex justify-between items-center border-b border-terminal-border pb-1.5 mb-2.5"
    >
      <span
        class="text-[0.75rem] uppercase tracking-[0.15em] text-terminal-dim"
      >
        Recent Notes
      </span>
      <a
        href="/notes/"
        class="text-[0.75rem] text-terminal-faint no-underline hover:text-terminal-green transition-colors duration-150"
        data-astro-prefetch
      >
        all notes &rarr;
      </a>
    </div>

    <ul class="list-none p-0">
      {
        recentNotes.map(({ data, id }, i) => {
          const { title, pubDate, summary, category } = data;
          const color = tagColors[category];
          return (
            <li
              class="note-card"
              style={`animation: fadeUp 0.3s ease both; animation-delay: ${i * 0.05}s`}
            >
              <a
                href={`/notes/${id}/`}
                class="block no-underline group p-[1.15rem_1.25rem]"
                data-astro-prefetch
              >
                <div class="flex justify-between items-baseline gap-4 mb-1">
                  <span class="text-terminal-text text-base font-medium transition-colors duration-150 group-hover:text-terminal-green">
                    {title}
                  </span>
                  <span class="flex items-baseline gap-2 shrink-0">
                    <span
                      class:list={[
                        "text-[0.65rem] uppercase tracking-wider px-1.5 py-0.5 border rounded",
                        color.border,
                        color.text,
                      ]}
                    >
                      {category}
                    </span>
                    <span class="text-terminal-faint text-[0.8rem] whitespace-nowrap">
                      {formatDate(pubDate)}
                    </span>
                  </span>
                </div>
                <div class="text-terminal-dim text-[0.9rem] font-light">
                  {summary}
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</BaseLayout>

<style>
  .cursor {
    display: inline-block;
    width: 0.5em;
    height: 1em;
    background: theme("colors.terminal.green");
    margin-left: 2px;
    vertical-align: -0.15em;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
</style>
