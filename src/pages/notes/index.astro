---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate, tagColors } from "@lib/notes.ts";

const notes = await getCollection("notes");
const sortedNotes = notes.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = ["all", ...new Set(sortedNotes.map((n) => n.data.category))];
---

<BaseLayout
  pageTitle="Notes | Hyun Don Moon"
  pageDescription="My notes on web development and personal updates."
>
  <div
    class="flex justify-between items-center pb-3 border-b border-terminal-border mb-4"
  >
    <span class="text-[0.7rem] uppercase tracking-[0.15em] text-terminal-dim">
      All Posts
    </span>
    <span class="text-[0.7rem] text-terminal-faint">
      {sortedNotes.length} entries
    </span>
  </div>

  <div class="flex gap-2 mb-4">
    {
      categories.map((cat) => (
        <button
          class:list={[
            "category-btn",
            "px-3 py-1 text-[0.75rem] border rounded transition-colors duration-150 cursor-pointer bg-transparent",
            cat === "all"
              ? "border-terminal-green text-terminal-green"
              : "border-terminal-border text-terminal-dim hover:border-terminal-dim",
          ]}
          data-category={cat}
        >
          {cat}
        </button>
      ))
    }
  </div>

  <ul class="list-none p-0">
    {
      sortedNotes.map(({ data, id }, i) => {
        const { title, pubDate, summary, category } = data;
        const color = tagColors[category];
        return (
          <li
            class="note-card"
            data-category={category}
            style={`animation: fadeUp 0.3s ease both; animation-delay: ${Math.min(i * 0.05, 0.3)}s`}
          >
            <a
              href={`/notes/${id}/`}
              class="block no-underline group p-[1.15rem_1.25rem]"
              data-astro-prefetch
            >
              <div class="flex justify-between items-baseline gap-4 mb-1">
                <span class="text-terminal-text text-[0.9rem] font-medium transition-colors duration-150 group-hover:text-terminal-green">
                  {title}
                </span>
                <span class="flex items-baseline gap-2 shrink-0">
                  <span
                    class:list={[
                      "text-[0.65rem] uppercase tracking-wider px-1.5 py-0.5 border rounded",
                      color.border,
                      color.text,
                    ]}
                  >
                    {category}
                  </span>
                  <span class="text-terminal-faint text-[0.75rem] whitespace-nowrap">
                    {formatDate(pubDate)}
                  </span>
                </span>
              </div>
              <div class="text-terminal-dim text-[0.8rem] font-light">
                {summary}
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".category-btn");
  const cards = document.querySelectorAll<HTMLLIElement>(".note-card");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category;

      buttons.forEach((b) => {
        if (b === btn) {
          b.classList.remove(
            "border-terminal-border",
            "text-terminal-dim",
            "hover:border-terminal-dim",
          );
          b.classList.add("border-terminal-green", "text-terminal-green");
        } else {
          b.classList.remove("border-terminal-green", "text-terminal-green");
          b.classList.add(
            "border-terminal-border",
            "text-terminal-dim",
            "hover:border-terminal-dim",
          );
        }
      });

      cards.forEach((card) => {
        if (category === "all" || card.dataset.category === category) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>

