---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout pageTitle="404 | hyundon.dev" pageDescription="Page Not Found">
  <div class="my-16 md:my-24 font-mono text-[0.85rem] leading-[1.9]">
    <div
      class="text-terminal-text"
      style="animation: fadeUp 0.3s ease both; animation-delay: 0s"
    >
      <span class="text-terminal-green">visitor@hyundon.dev</span>:<span
        class="text-terminal-purple">~</span
      >$ find . -name "page"
    </div>

    <div
      class="text-terminal-amber mt-2"
      style="animation: fadeUp 0.3s ease both; animation-delay: 0.05s"
    >
      ⚠ Error 404: page vanished into the void
    </div>

    <div
      class="text-terminal-dim border-l-2 border-terminal-border pl-3 my-3"
      style="animation: fadeUp 0.3s ease both; animation-delay: 0.1s"
    >
      <div>search completed in 0.042s</div>
      <div>directories scanned: 1,337</div>
      <div>results found: 0</div>
      <div>coffee consumed: 3 cups</div>
    </div>

    <div
      class="text-terminal-dim mt-4"
      style="animation: fadeUp 0.3s ease both; animation-delay: 0.15s"
    >
      Try one of these instead:
    </div>

    <div
      class="flex flex-col gap-1 mt-2"
      style="animation: fadeUp 0.3s ease both; animation-delay: 0.2s"
    >
      <a
        href="/"
        class="text-terminal-faint no-underline transition-all duration-150 hover:text-terminal-green hover:green-glow flex items-center gap-2"
      >
        <span class="text-terminal-faint">~</span> home
      </a>
      <a
        href="/notes/"
        class="text-terminal-faint no-underline transition-all duration-150 hover:text-terminal-green hover:green-glow flex items-center gap-2"
      >
        <span class="text-terminal-faint">~</span> notes
      </a>
      <a
        href="/about/"
        class="text-terminal-faint no-underline transition-all duration-150 hover:text-terminal-green hover:green-glow flex items-center gap-2"
      >
        <span class="text-terminal-faint">~</span> about
      </a>
    </div>
  </div>
</BaseLayout>
